# === 必填 ===
GEMINI_API_KEY=          # https://aistudio.google.com/apikey
GEMINI_READ_TIMEOUT_SECONDS=300
GEMINI_MAX_RETRIES=2
FINMIND_TOKEN=           # https://finmindtrade.com 免費註冊

# === 選配 ===
OPENROUTER_API_KEY=      # 最後備援（Google 整把 key 被限流時）
JOB_TOKEN=               # 方案 B 雲端部署時，GitHub Actions 觸發排程用的隨機長字串
ALERT_WEBHOOK_URL=       # 選配；警示觸發時 POST {text, events}

# === 基礎設施（本機 Docker 預設值即可）===
# DATABASE_URL=sqlite:////data/app.db      # 方案 B 改成 Neon 的 postgres://...
# SCHEDULER_MODE=internal                  # 方案 B 改 external
# CORS_ORIGINS=http://localhost:3000
